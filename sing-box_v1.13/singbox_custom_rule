{
  "experimental": {
    "clash_api": {
      "external_controller": "0.0.0.0:9090",
      "external_ui": "ui",
      "secret": "",
      "external_ui_download_url": "https://github.com/Zephyruso/zashboard/releases/latest/download/dist.zip",
      "external_ui_download_detour": "Default",
      "default_mode": "rule"
    },
    "cache_file": {
      "enabled": true,
      "store_fakeip": true
    }
  },
  "log": {
    "level": "info",
    "timestamp": true
  },
  "dns": {
    "servers": [
      {
        "tag": "proxy_dns",
        "type": "https",
        "server": "8.8.8.8",
        "detour": "Default"
      },
      {
        "tag": "cn_dns",
        "type": "udp",
        "server": "223.5.5.5"
      },
      {
        "tag": "fake_dns",
        "type": "fakeip",
        "inet4_range": "198.18.0.0/15"
      },
      {
        "tag": "block_dns",
        "type": "static",
        "rules": [
          {
            "server": "cn_dns"
          }
        ]
      }
    ],
    "rules": [
      {
        "rule_set": ["Category-Ads", "google-ads"],
        "action": "reject",
        "method": "rcode",
        "code": "refused"
      },
      {
        "clash_mode": "direct",
        "server": "cn_dns"
      },
      {
        "clash_mode": "global",
        "server": "fake_dns"
      },
      {
        "rule_set": "cnsite",
        "server": "cn_dns"
      },
      {
        "query_type": ["A", "AAAA"],
        "server": "fake_dns"
      }
    ],
    "final": "cn_dns"
  },
  "inbounds": [
    {
      "type": "tun",
      "tag": "tun-in",
      "interface_name": "singbox_tun",
      "address": ["172.19.0.1/30"],
      "auto_route": true,
      "strict_route": true,
      "stack": "mixed",
      "mtu": 1500
    }
  ],
  "outbounds": [
    {
      "type": "selector",
      "tag": "Default",
      "outbounds": ["Auto"]
    },
    {
      "type": "urltest",
      "tag": "Auto",
      "outbounds": [],
      "interval": "3m"
    },
    {
      "type": "direct",
      "tag": "Direct-Out"
    },
    {
      "type": "block",
      "tag": "Block"
    },
    {
      "type": "selector",
      "tag": "Streaming-Media",
      "outbounds": ["Default"]
    },
    {
      "type": "selector",
      "tag": "AI-Service",
      "outbounds": ["Default"]
    }
  ],
  "route": {
    "auto_detect_interface": true,
    "rule_set": [
      {
        "tag": "cnsite",
        "type": "remote",
        "format": "binary",
        "url": "https://github.com/MetaCubeX/meta-rules-dat/raw/refs/heads/sing/geo/geosite/cn.srs"
      },
      {
        "tag": "cnip",
        "type": "remote",
        "format": "binary",
        "url": "https://github.com/MetaCubeX/meta-rules-dat/raw/refs/heads/sing/geo/geoip/cn.srs"
      },
      {
        "tag": "Category-Ads",
        "type": "remote",
        "format": "binary",
        "url": "https://github.com/MetaCubeX/meta-rules-dat/raw/refs/heads/sing/geo/geosite/category-ads-all.srs"
      },
      {
        "tag": "google-ads",
        "type": "remote",
        "format": "binary",
        "url": "https://github.com/MetaCubeX/meta-rules-dat/raw/refs/heads/sing/geo/geosite/google-ads.srs"
      }
    ],
    "rules": [
      {
        "protocol": "dns",
        "action": "hijack-dns"
      },
      {
        "rule_set": ["Category-Ads", "google-ads"],
        "action": "reject",
        "method": "rcode",
        "code": "refused"
      },
      {
        "type": "logical",
        "mode": "and",
        "rules": [
          { "rule_set": ["Category-Ads", "google-ads"] },
          { "network": "udp" },
          { "port": 443 }
        ],
        "action": "reject"
      },
      {
        "rule_set": "cnsite",
        "outbound": "Direct-Out"
      },
      {
        "rule_set": "cnip",
        "outbound": "Direct-Out"
      },
      {
        "ip_is_private": true,
        "outbound": "Direct-Out"
      }
    ],
    "final": "Default"
  }
}
